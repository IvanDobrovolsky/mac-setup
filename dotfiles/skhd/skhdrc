# Navigation (Alt + Arrows)
alt - left  : yabai -m window --focus west
alt - down  : yabai -m window --focus south
alt - up    : yabai -m window --focus north
alt - right : yabai -m window --focus east

# Move Windows (Alt + Shift + Arrows)
alt + shift - left  : yabai -m window --warp west
alt + shift - down  : yabai -m window --warp south
alt + shift - up    : yabai -m window --warp north
alt + shift - right : yabai -m window --warp east

# Float / Unfloat (Alt + t)
alt - t : yabai -m window --toggle float

# Toggle Split (Alt + e)
alt - e : yabai -m window --toggle split

# --- Application Shortcuts ---

# Cmd + Shift + D -> Discord
cmd + shift - d : open -a "Discord"

# Cmd + Shift + W -> WhatsApp
cmd + shift - w : open -a "WhatsApp"

# Cmd + Shift + C -> VS Code
cmd + shift - c : open -a "Visual Studio Code"

# Cmd + Return -> Ghostty terminal
cmd - return : open -n -a "Ghostty"

# Cmd + Shift + B -> Google Chrome
cmd + shift - b : open -a "Google Chrome"

# Cmd + Shift + A -> open gemini app
# Assuming "Gemini" is the app name, or using Chrome to open the URL as fallback if app not found.
cmd + shift - a : open -a "Google Chrome" "https://gemini.google.com/app"

# Cmd + Shift + P -> 1 password
# Note: This overrides VS Code command palette if focused.
cmd + shift - p : open -a "1Password"

